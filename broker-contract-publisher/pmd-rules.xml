<?xml version="1.0"?>
<ruleset name="Stubborn Code Quality"
	xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

	<description>
		Code quality rules for Stubborn.
		Excluded intentionally:
		- LooseCoupling: false positives on external SDK types
		- AvoidFieldNameMatchingMethodName: false positives on records
		- AvoidCatchingGenericException: handled via SpotBugs
	</description>

	<!-- Design: class/method size thresholds -->
	<rule ref="category/java/design.xml/TooManyMethods">
		<properties>
			<property name="maxmethods" value="20"/>
		</properties>
	</rule>
	<rule ref="category/java/design.xml/ExcessiveParameterList">
		<properties>
			<property name="minimum" value="12"/>
		</properties>
	</rule>
	<rule ref="category/java/design.xml/CouplingBetweenObjects">
		<properties>
			<property name="threshold" value="40"/>
		</properties>
	</rule>

	<!-- Class length (PMD 7 XPath) -->
	<rule name="ExcessiveClassLength"
		language="java"
		message="Class is too long (more than 300 lines). Extract helper classes."
		class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
		<description>Classes longer than 300 lines should be split into smaller collaborating classes.</description>
		<priority>3</priority>
		<properties>
			<property name="xpath">
				<value>//TypeDeclaration[@EndLine - @BeginLine > 300]</value>
			</property>
		</properties>
	</rule>

	<!-- Method length (PMD 7 XPath) -->
	<rule name="ExcessiveMethodLength"
		language="java"
		message="Method is too long (more than 30 lines). Extract sub-methods."
		class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
		<description>Methods longer than 30 lines should be broken into smaller, focused methods.</description>
		<priority>3</priority>
		<properties>
			<property name="xpath">
				<value>//MethodDeclaration[@EndLine - @BeginLine > 30]</value>
			</property>
		</properties>
	</rule>

	<!-- Best practices -->
	<rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
	<rule ref="category/java/bestpractices.xml/UnusedPrivateField"/>
	<rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>
	<rule ref="category/java/bestpractices.xml/PreserveStackTrace"/>
	<rule ref="category/java/bestpractices.xml/MissingOverride"/>
	<rule ref="category/java/bestpractices.xml/UseTryWithResources"/>

	<!-- Code style -->
	<rule ref="category/java/codestyle.xml/UnnecessaryImport"/>

	<!-- Error prone -->
	<rule ref="category/java/errorprone.xml/EmptyCatchBlock">
		<properties>
			<property name="allowCommentedBlocks" value="true"/>
		</properties>
	</rule>

</ruleset>
