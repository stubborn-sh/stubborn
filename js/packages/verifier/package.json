{
  "name": "@stubborn-sh/verifier",
  "version": "0.0.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@stubborn-sh/broker-client": "0.0.4",
    "@stubborn-sh/stub-server": "0.0.4"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
